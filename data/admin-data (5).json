/* ═══════════════════════════════════════════════════════════════
   Omar Hamed Yousef — Portfolio Stylesheet
   Premium Dark-Mode Design System
   ═══════════════════════════════════════════════════════════════ */

/* ─── Design Tokens ─────────────────────────────────────────── */
:root {
  /* Palette */
  --bg-primary:    #0a0a0f;
  --bg-secondary:  #12121a;
  --bg-card:       rgba(255, 255, 255, 0.03);
  --bg-card-hover: rgba(255, 255, 255, 0.06);
  --accent-1:      #6c5ce7;
  --accent-2:      #a855f7;
  --accent-3:      #00d4ff;
  --text-primary:  #f0f0f5;
  --text-secondary:#8888aa;
  --border:        rgba(255, 255, 255, 0.06);
  --border-hover:  rgba(255, 255, 255, 0.12);

  /* Gradient shortcuts */
  --gradient-accent: linear-gradient(135deg, var(--accent-1), var(--accent-2));
  --gradient-glow:   linear-gradient(135deg, var(--accent-1), var(--accent-3));

  /* Typography */
  --font-heading: 'Outfit', sans-serif;
  --font-body:    'Inter', sans-serif;

  /* Spacing */
  --section-pad: clamp(80px, 10vw, 140px);
  --container:   1200px;

  /* Misc */
  --radius:   16px;
  --radius-sm: 8px;
  --transition: 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --transition-fast: 0.2s ease;

  /* Nav */
  --nav-height: 72px;
}

/* ─── Reset & Base ──────────────────────────────────────────── */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html {
  scroll-behavior: smooth;
  scrollbar-width: thin;
  scrollbar-color: var(--accent-1) var(--bg-secondary);
  font-size: 16px;
}

body {
  font-family: var(--font-body);
  background: var(--bg-primary);
  color: var(--text-primary);
  line-height: 1.7;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

::selection {
  background: var(--accent-1);
  color: #fff;
}

::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg-secondary); }
::-webkit-scrollbar-thumb {
  background: var(--accent-1);
  border-radius: 3px;
}

img { max-width: 100%; height: auto; display: block; }
a { text-decoration: none; color: inherit; }
ul, ol { list-style: none; }

h1, h2, h3, h4, h5, h6 { font-family: var(--font-heading); font-weight: 700; line-height: 1.2; }

/* ─── Utility ───────────────────────────────────────────────── */
.container {
  width: 90%;
  max-width: var(--container);
  margin: 0 auto;
}

.section-header {
  text-align: center;
  margin-bottom: 64px;
}

.section-label {
  display: inline-block;
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 3px;
  background: var(--gradient-accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 16px;
}

.section-title {
  font-size: clamp(2rem, 4vw, 3rem);
  color: var(--text-primary);
  margin-bottom: 16px;
}

.section-subtitle {
  color: var(--text-secondary);
  font-size: 1.05rem;
  max-width: 560px;
  margin: 0 auto;
}

/* ─── Scroll Animations ────────────────────────────────────── */
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.reveal-left {
  opacity: 0;
  transform: translateX(-40px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal-left.visible {
  opacity: 1;
  transform: translateX(0);
}

.reveal-right {
  opacity: 0;
  transform: translateX(40px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal-right.visible {
  opacity: 1;
  transform: translateX(0);
}

.reveal-scale {
  opacity: 0;
  transform: scale(0.92);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.reveal-scale.visible {
  opacity: 1;
  transform: scale(1);
}

/* ─── Loading Screen ────────────────────────────────────────── */
.loading-screen {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: opacity 0.6s ease, visibility 0.6s ease;
}
.loading-screen.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.loader-ring {
  width: 48px;
  height: 48px;
  border: 3px solid var(--border);
  border-top-color: var(--accent-2);
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}
.loader-text {
  margin-top: 20px;
  font-family: var(--font-heading);
  font-size: 0.85rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--text-secondary);
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ─── Navigation ────────────────────────────────────────────── */
.main-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: var(--nav-height);
  z-index: 1000;
  display: flex;
  align-items: center;
  transition: background var(--transition), box-shadow var(--transition), backdrop-filter var(--transition);
}
.main-nav.scrolled {
  background: rgba(10, 10, 15, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 1px 0 var(--border);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 90%;
  max-width: var(--container);
  margin: 0 auto;
}

.nav-logo {
  font-family: var(--font-heading);
  font-size: 1.3rem;
  font-weight: 700;
  background: var(--gradient-accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.nav-links {
  display: flex;
  gap: 36px;
  align-items: center;
}

.nav-links a {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-secondary);
  transition: color var(--transition-fast);
  position: relative;
}
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--gradient-accent);
  border-radius: 1px;
  transition: width var(--transition);
}
.nav-links a:hover,
.nav-links a.active {
  color: var(--text-primary);
}
.nav-links a:hover::after,
.nav-links a.active::after {
  width: 100%;
}

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 4px;
  background: none;
  border: none;
}
.nav-toggle span {
  width: 24px;
  height: 2px;
  background: var(--text-primary);
  border-radius: 2px;
  transition: transform var(--transition), opacity var(--transition);
}
.nav-toggle.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-toggle.active span:nth-child(2) { opacity: 0; }
.nav-toggle.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ─── Hero Section ──────────────────────────────────────────── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 0 5%;
}

/* Particle canvas */
.hero-particles {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}

/* Animated gradient background */
.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 40%, rgba(108, 92, 231, 0.15) 0%, transparent 60%),
    radial-gradient(ellipse 60% 50% at 80% 70%, rgba(168, 85, 247, 0.1) 0%, transparent 50%),
    radial-gradient(ellipse 50% 40% at 20% 80%, rgba(0, 212, 255, 0.08) 0%, transparent 50%),
    var(--bg-primary);
  animation: heroBgShift 12s ease-in-out infinite alternate;
}

@keyframes heroBgShift {
  0%   { filter: hue-rotate(0deg); }
  100% { filter: hue-rotate(15deg); }
}

/* Floating orbs */
.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.35;
  pointer-events: none;
}
.hero-orb--1 {
  width: 400px; height: 400px;
  background: var(--accent-1);
  top: -10%; left: -5%;
  animation: orbFloat 8s ease-in-out infinite alternate;
}
.hero-orb--2 {
  width: 300px; height: 300px;
  background: var(--accent-2);
  bottom: -5%; right: -5%;
  animation: orbFloat 10s ease-in-out infinite alternate-reverse;
}
.hero-orb--3 {
  width: 200px; height: 200px;
  background: var(--accent-3);
  top: 40%; right: 20%;
  animation: orbFloat 7s ease-in-out infinite alternate;
}

@keyframes orbFloat {
  0%   { transform: translate(0, 0) scale(1); }
  50%  { transform: translate(30px, -20px) scale(1.05); }
  100% { transform: translate(-20px, 30px) scale(0.95); }
}

/* Noise / grain overlay */
.hero::after {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 150px;
  pointer-events: none;
  z-index: 1;
}

/* Hero Split Layout */
.hero-split {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  width: 90%;
  max-width: var(--container);
}

.hero-content {
  position: relative;
  z-index: 3;
  text-align: left;
  max-width: 580px;
  flex: 1;
}

/* Hero Photo — Cinematic fade from bottom */
.hero-photo-wrap {
  position: absolute;
  right: -5%;
  bottom: 0;
  z-index: 1;
  pointer-events: none;
  width: 85%;
  max-width: 1000px;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
}

.hero-photo-glow {
  position: absolute;
  bottom: 10%;
  right: 20%;
  width: 350px;
  height: 350px;
  background: radial-gradient(ellipse at center, rgba(108, 92, 231, 0.3) 0%, rgba(168, 85, 247, 0.15) 40%, transparent 70%);
  border-radius: 50%;
  filter: blur(60px);
  animation: glowPulse 4s ease-in-out infinite alternate;
  pointer-events: none;
}

@keyframes glowPulse {
  0%   { opacity: 0.5; transform: scale(1); }
  100% { opacity: 1;   transform: scale(1.15); }
}

.hero-photo {
  position: relative;
  width: 100%;
  max-height: 90vh;
  overflow: visible;
}

.hero-photo img {
  width: 100%;
  height: auto;
  display: block;
  mix-blend-mode: screen;
  opacity: 0.7;
  -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0) 0%, rgba(0,0,0,0.15) 10%, rgba(0,0,0,0.5) 30%, rgba(0,0,0,0.7) 50%, rgba(0,0,0,0.85) 70%, rgba(0,0,0,1) 100%);
  mask-image: linear-gradient(to top, rgba(0,0,0,0) 0%, rgba(0,0,0,0.15) 10%, rgba(0,0,0,0.5) 30%, rgba(0,0,0,0.7) 50%, rgba(0,0,0,0.85) 70%, rgba(0,0,0,1) 100%);
  filter: brightness(1.2) contrast(1.1);
  animation: fadeInPhoto 1.2s ease forwards;
  animation-delay: 0.3s;
  opacity: 0;
}

@keyframes fadeInPhoto {
  from { opacity: 0; transform: translateY(40px) scale(0.98); }
  to   { opacity: 0.7; transform: translateY(0) scale(1); }
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 20px;
  border-radius: 100px;
  background: rgba(108, 92, 231, 0.12);
  border: 1px solid rgba(108, 92, 231, 0.25);
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--accent-2);
  margin-bottom: 28px;
  animation: fadeInDown 0.8s ease forwards;
}
.hero-badge .dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #4ade80;
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.4); }
}

.hero-name {
  font-size: clamp(2.2rem, 5vw, 4rem);
  font-weight: 700;
  margin-bottom: 16px;
  animation: fadeInUp 0.8s ease forwards;
  animation-delay: 0.15s;
  opacity: 0;
}
.hero-name .name-gradient {
  background: var(--gradient-accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-title {
  font-family: var(--font-heading);
  font-size: clamp(1.1rem, 2.5vw, 1.5rem);
  font-weight: 400;
  color: var(--text-secondary);
  margin-bottom: 12px;
  animation: fadeInUp 0.8s ease forwards;
  animation-delay: 0.3s;
  opacity: 0;
}

/* Typing effect tagline */
.hero-tagline {
  font-family: var(--font-heading);
  font-size: clamp(1rem, 2vw, 1.25rem);
  font-weight: 600;
  min-height: 1.5em;
  margin-bottom: 20px;
  background: var(--gradient-glow);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: fadeInUp 0.8s ease forwards;
  animation-delay: 0.35s;
  opacity: 0;
}
.hero-tagline::after {
  content: '|';
  display: inline-block;
  -webkit-text-fill-color: var(--accent-3);
  animation: blink-cursor 0.7s step-end infinite;
  margin-left: 2px;
}
@keyframes blink-cursor {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

.hero-desc {
  font-size: 1.05rem;
  color: var(--text-secondary);
  max-width: 520px;
  margin: 0 0 40px;
  line-height: 1.8;
  animation: fadeInUp 0.8s ease forwards;
  animation-delay: 0.45s;
  opacity: 0;
}

.hero-cta {
  display: flex;
  gap: 16px;
  justify-content: flex-start;
  flex-wrap: wrap;
  animation: fadeInUp 0.8s ease forwards;
  animation-delay: 0.6s;
  opacity: 0;
}

/* Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 32px;
  border-radius: 100px;
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
}
.btn:hover { transform: translateY(-2px); }

.btn-primary {
  background: var(--gradient-accent);
  color: #fff;
  box-shadow: 0 4px 24px rgba(108, 92, 231, 0.35);
}
.btn-primary:hover {
  box-shadow: 0 8px 32px rgba(108, 92, 231, 0.5);
}

.btn-outline {
  background: transparent;
  color: var(--text-primary);
  border: 1px solid var(--border-hover);
}
.btn-outline:hover {
  border-color: var(--accent-1);
  background: rgba(108, 92, 231, 0.08);
}

/* Scroll indicator */
.scroll-indicator {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  animation: fadeInUp 0.8s ease forwards;
  animation-delay: 1s;
  opacity: 0;
}
.scroll-indicator span {
  font-size: 0.72rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-secondary);
}
.scroll-mouse {
  width: 22px;
  height: 34px;
  border: 2px solid var(--text-secondary);
  border-radius: 12px;
  position: relative;
}
.scroll-mouse::after {
  content: '';
  position: absolute;
  top: 6px;
  left: 50%;
  transform: translateX(-50%);
  width: 3px;
  height: 8px;
  background: var(--accent-2);
  border-radius: 2px;
  animation: scrollDot 1.8s ease-in-out infinite;
}
@keyframes scrollDot {
  0%   { opacity: 1; transform: translateX(-50%) translateY(0); }
  100% { opacity: 0; transform: translateX(-50%) translateY(12px); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ─── About Section ─────────────────────────────────────────── */
.about {
  padding: var(--section-pad) 0;
  background: var(--bg-secondary);
  position: relative;
}

.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: start;
}

.about-text p {
  color: var(--text-secondary);
  margin-bottom: 18px;
  font-size: 1rem;
  line-height: 1.85;
}

.about-text p:first-of-type::first-letter {
  font-size: 2.5rem;
  font-weight: 700;
  font-family: var(--font-heading);
  float: left;
  margin-right: 8px;
  line-height: 1;
  background: var(--gradient-accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Stats grid */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-top: 48px;
}

.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 28px 24px;
  text-align: center;
  transition: border-color var(--transition), transform var(--transition), background var(--transition);
}
.stat-card:hover {
  border-color: var(--accent-1);
  transform: translateY(-4px);
  background: var(--bg-card-hover);
}

.stat-number {
  font-family: var(--font-heading);
  font-size: 2.8rem;
  font-weight: 700;
  background: var(--gradient-accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.1;
}

.stat-label {
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin-top: 6px;
}

/* Skill chips */
.skills-section-title {
  font-size: 1.15rem;
  margin-bottom: 20px;
  color: var(--text-primary);
}

.skill-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.skill-chip {
  padding: 8px 18px;
  border-radius: 100px;
  font-size: 0.82rem;
  font-weight: 500;
  background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}
.skill-chip:hover {
  border-color: var(--accent-1);
  color: var(--text-primary);
  background: rgba(108, 92, 231, 0.1);
  transform: translateY(-2px);
}
.skill-chip.software {
  border-color: rgba(0, 212, 255, 0.2);
}
.skill-chip.software:hover {
  border-color: var(--accent-3);
  background: rgba(0, 212, 255, 0.08);
}

/* ─── Experience Section ────────────────────────────────────── */
.experience {
  padding: var(--section-pad) 0;
  background: var(--bg-primary);
}

.timeline {
  position: relative;
  max-width: 740px;
  margin: 0 auto;
  padding-left: 40px;
}
.timeline::before {
  content: '';
  position: absolute;
  top: 0;
  left: 11px;
  width: 2px;
  height: 100%;
  background: linear-gradient(to bottom, var(--accent-1), var(--accent-2), transparent);
  border-radius: 1px;
}

.timeline-item {
  position: relative;
  margin-bottom: 36px;
}

.timeline-dot {
  position: absolute;
  left: -40px;
  top: 6px;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--bg-primary);
  border: 2px solid var(--accent-1);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}
.timeline-dot::after {
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--accent-2);
}
.timeline-item.current .timeline-dot {
  border-color: var(--accent-3);
  box-shadow: 0 0 16px rgba(0, 212, 255, 0.4);
}
.timeline-item.current .timeline-dot::after {
  background: var(--accent-3);
}

.timeline-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px 28px;
  transition: border-color var(--transition), transform var(--transition), background var(--transition);
}
.timeline-card:hover {
  border-color: rgba(108, 92, 231, 0.3);
  transform: translateX(6px);
  background: var(--bg-card-hover);
}

.timeline-period {
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--accent-2);
  background: rgba(168, 85, 247, 0.1);
  padding: 4px 12px;
  border-radius: 100px;
  margin-bottom: 10px;
}
.timeline-item.current .timeline-period {
  color: var(--accent-3);
  background: rgba(0, 212, 255, 0.1);
}

.timeline-role {
  font-family: var(--font-heading);
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.timeline-company {
  font-size: 0.92rem;
  color: var(--text-secondary);
}

/* Education Card */
.education-card {
  max-width: 740px;
  margin: 48px auto 0;
  padding-left: 40px;
}
.education-inner {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px 28px;
  display: flex;
  align-items: center;
  gap: 20px;
}
.education-icon {
  width: 48px;
  height: 48px;
  min-width: 48px;
  border-radius: 12px;
  background: var(--gradient-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
}
.education-info h4 {
  font-size: 1.05rem;
  color: var(--text-primary);
}
.education-info p {
  font-size: 0.9rem;
  color: var(--text-secondary);
}

/* ─── Services Section ──────────────────────────────────────── */
.services {
  padding: var(--section-pad) 0;
  background: var(--bg-secondary);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.service-card {
  position: relative;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 36px 28px;
  transition: all var(--transition);
  overflow: hidden;
}
.service-card::before {
  content: '';
  position: absolute;
  inset: -1px;
  border-radius: var(--radius);
  padding: 1px;
  background: var(--gradient-accent);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity var(--transition);
}
.service-card:hover::before { opacity: 1; }
.service-card:hover {
  transform: translateY(-6px);
  background: var(--bg-card-hover);
}

/* Service icon with gradient background */
.service-icon-wrap {
  width: 56px;
  height: 56px;
  border-radius: 14px;
  background: var(--gradient-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  color: #fff;
  margin-bottom: 20px;
  transition: transform var(--transition);
}
.service-card:hover .service-icon-wrap {
  transform: scale(1.1) rotate(-5deg);
}

/* Fallback for emoji icons */
.service-icon {
  font-size: 2.2rem;
  margin-bottom: 20px;
  display: block;
}

.service-title {
  font-family: var(--font-heading);
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12px;
}

.service-desc {
  font-size: 0.92rem;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ─── Portfolio Section ─────────────────────────────────────── */
.portfolio {
  padding: var(--section-pad) 0;
  padding-bottom: 0;
  background: var(--bg-primary);
}

/* ─── Portfolio Sections Container ──────────────────────────── */
#portfolio-sections {
  margin-top: 24px;
}

/* ─── Individual Portfolio Section ──────────────────────────── */
.portfolio-section {
  padding: 80px 0 60px;
  position: relative;
}

.portfolio-section:nth-child(even) {
  background: var(--bg-secondary);
}

.portfolio-section-inner {
  width: 90%;
  max-width: var(--container);
  margin: 0 auto;
}

/* ─── Section Title — Bold & Large ──────────────────────────── */
.portfolio-section-title {
  font-family: var(--font-heading);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--text-primary);
  margin-bottom: 48px;
  position: relative;
  line-height: 1.1;
}

.portfolio-section-title::after {
  content: '';
  display: block;
  width: 60px;
  height: 4px;
  background: var(--gradient-accent);
  border-radius: 2px;
  margin-top: 16px;
}

/* ─── Portfolio Grid (Section Items) ────────────────────────── */
.section-items-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

/* ─── Portfolio Item Card ───────────────────────────────────── */
.portfolio-item {
  border-radius: var(--radius);
  overflow: hidden;
  position: relative;
  cursor: pointer;
  transition: transform var(--transition), opacity 0.4s ease;
}
.portfolio-item:hover { transform: scale(1.02); }

.portfolio-item.hiding {
  opacity: 0;
  transform: scale(0.92);
}
.portfolio-item.showing {
  opacity: 1;
  transform: scale(1);
}

.portfolio-img-wrap {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius);
  background: var(--bg-card);
}

.portfolio-img-wrap img {
  width: 100%;
  display: block;
  transition: transform 0.5s ease, opacity 0.5s ease;
  object-fit: cover;
  opacity: 0;
}
.portfolio-img-wrap img.loaded {
  opacity: 1;
}
.portfolio-item:hover .portfolio-img-wrap img {
  transform: scale(1.06);
}

.portfolio-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10, 10, 15, 0.9) 0%, rgba(10, 10, 15, 0.2) 50%, transparent 100%);
  display: flex;
  align-items: flex-end;
  padding: 24px;
  opacity: 0;
  transition: opacity var(--transition);
}
.portfolio-item:hover .portfolio-overlay { opacity: 1; }

.portfolio-overlay-content h3 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4px;
}
.portfolio-overlay-content span {
  font-size: 0.8rem;
  color: var(--accent-2);
  text-transform: uppercase;
  letter-spacing: 1px;
}

/* Placeholder / loading skeleton */
.portfolio-img-wrap .img-placeholder {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-secondary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  font-size: 0.8rem;
  transition: opacity 0.4s ease;
  min-height: 200px;
}

/* Skeleton shimmer animation */
.portfolio-img-wrap .img-placeholder::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.03) 50%,
    transparent 100%
  );
  animation: shimmer 1.5s ease-in-out infinite;
}
@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* ═══════════════════════════════════════════════════════════════
   CASE STUDY — Art Direction Layout
   ═══════════════════════════════════════════════════════════════ */

.case-study {
  display: grid;
  grid-template-columns: 2fr 3fr;
  gap: 0;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: border-color var(--transition), transform var(--transition), opacity 0.4s ease;
}

.case-study:hover {
  border-color: rgba(108, 92, 231, 0.25);
}

.case-study.hiding {
  opacity: 0;
  transform: scale(0.96);
}
.case-study.showing {
  opacity: 1;
  transform: scale(1);
}

/* ─── Art Direction Text (Left Side) ────────────────────── */
.case-study-text {
  padding: 40px 36px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border-right: 1px solid var(--border);
}

.case-study-art-title {
  font-family: var(--font-heading);
  font-size: 1.8rem;
  font-weight: 700;
  font-style: italic;
  color: #f5a623;
  margin-bottom: 28px;
  line-height: 1.2;
}

/* ─── Art Direction Header (Title + Logos) ───────────────── */
.case-study-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 28px;
}

.case-study-header .case-study-art-title {
  margin-bottom: 0;
}

/* ─── Logos — Bigger, No Frame, PNG Transparent ──────────── */
.case-study-logos {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-shrink: 0;
}

.case-study-logos img {
  height: 60px;
  width: auto;
  max-width: 160px;
  object-fit: contain;
  filter: brightness(0.95);
  transition: filter var(--transition-fast), transform var(--transition-fast);
  /* No border, no frame, transparent background */
  background: transparent;
  border: none;
  border-radius: 0;
}

.case-study-logos img:hover {
  filter: brightness(1.15);
  transform: scale(1.05);
}

.case-study-section {
  margin-bottom: 20px;
}
.case-study-section:last-child {
  margin-bottom: 0;
}

.case-study-section h4 {
  font-family: var(--font-heading);
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6px;
}

.case-study-section p {
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.75;
}

/* ─── Image Collage Grid (Right Side) ───────────────────── */
.case-study-gallery {
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding: 3px;
  background: var(--bg-secondary);
}

.gallery-row {
  display: flex;
  gap: 3px;
  width: 100%;
}

.gallery-row.top .gallery-cell {
  flex: 1;
}

.gallery-row.hero {
  flex: 1;
}

.gallery-row.hero .gallery-cell {
  flex: 1;
}

.gallery-cell {
  position: relative;
  overflow: hidden;
  border-radius: 6px;
  background: var(--bg-card);
  cursor: pointer;
}

.gallery-cell img {
  width: 100%;
  display: block;
  transition: transform 0.5s ease;
}

/* Top row: thumbnails — flexible, no crop */
.gallery-row.top .gallery-cell img {
  height: auto;
  object-fit: contain;
}

/* Hero row: fill available space */
.gallery-row.hero .gallery-cell img {
  height: 100%;
  object-fit: cover;
}

.gallery-cell:hover img {
  transform: scale(1.05);
}

/* Row heights */
.gallery-row.top {
  height: auto;
  align-items: flex-end;
}

.gallery-row.hero {
  flex: 1;
  min-height: 200px;
}

/* Empty cell placeholder */
.gallery-cell.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  font-size: 1.5rem;
  min-height: 80px;
}

/* ═══════════════════════════════════════════════════════════════
   VIDEO CARDS — AI Videos & Animation Section
   ═══════════════════════════════════════════════════════════════ */

.video-items-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 24px;
}

.video-card {
  position: relative;
  border-radius: var(--radius);
  overflow: hidden;
  background: var(--bg-card);
  border: 1px solid var(--border);
  transition: all var(--transition);
  cursor: pointer;
}

.video-card:hover {
  border-color: rgba(108, 92, 231, 0.35);
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
}

.video-thumbnail-wrap {
  position: relative;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: var(--bg-secondary);
}

.video-thumbnail-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
  opacity: 1 !important;
}

.video-no-thumb {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--bg-secondary), var(--bg-card));
  color: var(--text-secondary);
  font-size: 3rem;
  opacity: 0.5;
}

.video-card:hover .video-thumbnail-wrap img {
  transform: scale(1.06);
}

/* Play button overlay */
.video-play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: rgba(108, 92, 231, 0.85);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 1.6rem;
  transition: all var(--transition);
  box-shadow: 0 8px 32px rgba(108, 92, 231, 0.4);
}

.video-play-btn i {
  margin-left: 4px; /* optical centering for play icon */
}

.video-card:hover .video-play-btn {
  background: rgba(108, 92, 231, 1);
  transform: translate(-50%, -50%) scale(1.1);
  box-shadow: 0 12px 40px rgba(108, 92, 231, 0.6);
}

.video-card-info {
  padding: 16px 20px;
}

.video-card-info h4 {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.video-card-info p {
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* Video Frames Strip */
.video-frames-strip {
  display: flex;
  gap: 8px;
  padding: 0 20px 16px;
  overflow-x: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--accent-1) transparent;
}

.video-frames-strip::-webkit-scrollbar {
  height: 4px;
}

.video-frames-strip::-webkit-scrollbar-thumb {
  background: var(--accent-1);
  border-radius: 2px;
}

.video-frame {
  flex-shrink: 0;
  width: 80px;
  height: 80px;
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all var(--transition-fast);
}

.video-frame:hover {
  border-color: var(--accent-1);
  transform: scale(1.08);
}

.video-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  opacity: 1 !important;
}
/* ═══════════════════════════════════════════════════════════════
   LAYOUTS SECTION — Multi-image project sections (2-9 images)
   ═══════════════════════════════════════════════════════════════ */

.layout-project {
  margin-bottom: 48px;
}

.layout-project:last-child {
  margin-bottom: 0;
}

.layout-project-title {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 20px;
  padding-left: 4px;
  letter-spacing: 0.5px;
}

/* Base layout grid */
.layout-grid {
  display: grid;
  gap: 12px;
  border-radius: var(--radius);
}

/* 2 images: side by side */
.layout-grid.layout-grid-2 {
  grid-template-columns: repeat(2, 1fr);
}

/* 3 images: 3 columns */
.layout-grid.layout-grid-3 {
  grid-template-columns: repeat(3, 1fr);
}

/* 4 images: 2x2 */
.layout-grid.layout-grid-4 {
  grid-template-columns: repeat(2, 1fr);
}

/* 5 images: 3 top + 2 bottom centered */
.layout-grid.layout-grid-5 {
  grid-template-columns: repeat(6, 1fr);
}
.layout-grid.layout-grid-5 .layout-cell:nth-child(-n+3) {
  grid-column: span 2;
}
.layout-grid.layout-grid-5 .layout-cell:nth-child(4) {
  grid-column: 2 / span 2;
}
.layout-grid.layout-grid-5 .layout-cell:nth-child(5) {
  grid-column: 4 / span 2;
}

/* 6 images: 3x2 */
.layout-grid.layout-grid-6 {
  grid-template-columns: repeat(3, 1fr);
}

/* 7 images: 4 top + 3 bottom */
.layout-grid.layout-grid-7 {
  grid-template-columns: repeat(12, 1fr);
}
.layout-grid.layout-grid-7 .layout-cell:nth-child(-n+4) {
  grid-column: span 3;
}
.layout-grid.layout-grid-7 .layout-cell:nth-child(n+5) {
  grid-column: span 4;
}

/* 8 images: 4x2 */
.layout-grid.layout-grid-8 {
  grid-template-columns: repeat(4, 1fr);
}

/* 9 images: 3x3 */
.layout-grid.layout-grid-9 {
  grid-template-columns: repeat(3, 1fr);
}

/* Individual layout cell */
.layout-cell {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-sm);
  background: var(--bg-card);
  cursor: pointer;
}

.layout-cell img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: contain;
  transition: transform 0.5s ease;
}

.layout-cell:hover img {
  transform: scale(1.03);
}

/* Subtle overlay on hover */
.layout-cell::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(108, 92, 231, 0);
  transition: background 0.3s ease;
  pointer-events: none;
}

.layout-cell:hover::after {
  background: rgba(108, 92, 231, 0.06);
}

/* ═══════════════════════════════════════════════════════════════
   SOCIAL MEDIA SLIDER / CAROUSEL
   ═══════════════════════════════════════════════════════════════ */

.social-slider {
  position: relative;
  padding: 0 48px;
}

.slider-viewport {
  overflow: hidden;
  border-radius: var(--radius);
}

.slider-track {
  display: flex;
  transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
}

.slider-slide {
  flex: 0 0 25%;
  padding: 0 8px;
  box-sizing: border-box;
}

.slider-img-wrap {
  border-radius: var(--radius);
  overflow: hidden;
  background: var(--bg-card);
  border: 1px solid var(--border);
  transition: all var(--transition);
  cursor: pointer;
}

.slider-img-wrap:hover {
  border-color: rgba(108, 92, 231, 0.3);
  transform: translateY(-4px);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
}

.slider-img-wrap img {
  width: 100%;
  display: block;
  object-fit: cover;
  aspect-ratio: 1 / 1;
  transition: transform 0.5s ease;
}

.slider-img-wrap:hover img {
  transform: scale(1.05);
}

.slider-caption {
  padding: 12px 4px 4px;
  text-align: center;
}

.slider-caption h4 {
  font-family: var(--font-heading);
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--text-secondary);
}

/* Slider Arrows */
.slider-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  color: var(--text-primary);
  font-size: 1rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
}

.slider-arrow:hover {
  background: var(--accent-1);
  border-color: var(--accent-1);
  color: #fff;
  box-shadow: 0 4px 20px rgba(108, 92, 231, 0.4);
}

.slider-prev { left: 0; }
.slider-next { right: 0; }

/* Slider Dots */
.slider-dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 24px;
}

.slider-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  border: none;
  background: var(--border);
  cursor: pointer;
  transition: all var(--transition-fast);
  padding: 0;
}

.slider-dot.active {
  background: var(--accent-1);
  transform: scale(1.3);
  box-shadow: 0 0 8px rgba(108, 92, 231, 0.5);
}

.slider-dot:hover {
  background: var(--accent-2);
}

/* ═══════════════════════════════════════════════════════════════
   CLIENT LOGOS MARQUEE — Auto-scrolling infinite loop
   ═══════════════════════════════════════════════════════════════ */

.logos-marquee {
  overflow: hidden;
  padding: 20px 0;
  mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
}

.marquee-track {
  display: flex;
  align-items: center;
  gap: 60px;
  animation: marquee-scroll 30s linear infinite;
  width: max-content;
}

.marquee-track:hover {
  animation-play-state: paused;
}

@keyframes marquee-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.marquee-logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80px;
  padding: 0 10px;
  transition: all var(--transition-fast);
}

.marquee-logo img {
  height: 60px;
  width: auto;
  max-width: 180px;
  object-fit: contain;
  filter: grayscale(100%) brightness(0.7);
  opacity: 0.6;
  transition: all 0.4s ease;
}

.marquee-logo:hover img {
  filter: grayscale(0%) brightness(1);
  opacity: 1;
  transform: scale(1.1);
}


/* ═══════════════════════════════════════════════════════════════
   THANK YOU Section
   ═══════════════════════════════════════════════════════════════ */

.thank-you {
  padding: 120px 0;
  background: var(--bg-primary);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.thank-you::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(108, 92, 231, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.thank-you-content {
  position: relative;
  z-index: 1;
}

.thank-you-title {
  font-family: var(--font-heading);
  font-size: clamp(3.5rem, 8vw, 7rem);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 8px;
  background: var(--gradient-accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 20px;
  line-height: 1;
}

.thank-you-subtitle {
  font-size: 1.15rem;
  color: var(--text-secondary);
  max-width: 500px;
  margin: 0 auto 40px;
  line-height: 1.7;
}

.thank-you-social {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-bottom: 36px;
}

.thank-you-social .social-link {
  width: 52px;
  height: 52px;
  border-radius: 14px;
  font-size: 1.2rem;
}

.thank-you-cta {
  display: inline-flex;
}

/* ─── Contact Section ───────────────────────────────────────── */
.contact {
  padding: var(--section-pad) 0;
  background: var(--bg-secondary);
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: start;
}

.contact-info { padding-right: 24px; }

.contact-info h3 {
  font-size: 1.8rem;
  margin-bottom: 20px;
  background: var(--gradient-accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.contact-info > p {
  color: var(--text-secondary);
  margin-bottom: 32px;
  line-height: 1.8;
}

.contact-detail {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
}

.contact-detail-icon {
  width: 44px;
  height: 44px;
  min-width: 44px;
  border-radius: 12px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent-2);
  font-size: 1rem;
}

.contact-detail-text a,
.contact-detail-text span {
  font-size: 0.95rem;
  color: var(--text-primary);
  transition: color var(--transition-fast);
}
.contact-detail-text a:hover { color: var(--accent-2); }
.contact-detail-text small {
  display: block;
  font-size: 0.78rem;
  color: var(--text-secondary);
}

.social-links {
  display: flex;
  gap: 12px;
  margin-top: 32px;
}

.social-link {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  font-size: 1.1rem;
  transition: all var(--transition-fast);
}
.social-link:hover {
  border-color: var(--accent-1);
  color: var(--accent-2);
  transform: translateY(-3px);
  background: rgba(108, 92, 231, 0.1);
}

/* Contact form */
.contact-form {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 40px;
}

.form-group {
  margin-bottom: 20px;
}

.form-group label {
  display: block;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 8px;
}

.form-group input,
.form-group textarea {
  width: 100%;
  padding: 14px 18px;
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid var(--border);
  color: var(--text-primary);
  font-family: var(--font-body);
  font-size: 0.95rem;
  transition: border-color var(--transition), box-shadow var(--transition);
  outline: none;
}
.form-group input:focus,
.form-group textarea:focus {
  border-color: var(--accent-1);
  box-shadow: 0 0 0 3px rgba(108, 92, 231, 0.15);
}
.form-group input::placeholder,
.form-group textarea::placeholder {
  color: rgba(136, 136, 170, 0.5);
}

.form-group textarea { min-height: 140px; resize: vertical; }

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.form-submit {
  width: 100%;
  margin-top: 8px;
}

.form-success {
  display: none;
  text-align: center;
  padding: 24px;
  background: rgba(74, 222, 128, 0.08);
  border: 1px solid rgba(74, 222, 128, 0.2);
  border-radius: var(--radius-sm);
  margin-top: 16px;
  color: #4ade80;
  font-size: 0.95rem;
}
.form-success.show { display: block; animation: fadeInUp 0.4s ease; }

/* ─── Footer ────────────────────────────────────────────────── */
.site-footer {
  padding: 40px 0;
  border-top: 1px solid var(--border);
  background: var(--bg-primary);
}

.footer-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 16px;
}

.footer-copy {
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.footer-links {
  display: flex;
  gap: 12px;
}

.footer-links a {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  font-size: 0.95rem;
  transition: all var(--transition-fast);
}
.footer-links a:hover {
  border-color: var(--accent-1);
  color: var(--accent-2);
  transform: translateY(-2px);
}

/* ─── Back to Top ───────────────────────────────────────────── */
.back-to-top {
  position: fixed;
  bottom: 32px;
  right: 32px;
  z-index: 900;
  width: 48px;
  height: 48px;
  border-radius: 14px;
  background: var(--gradient-accent);
  border: none;
  color: #fff;
  font-size: 1.1rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transform: translateY(20px);
  transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  box-shadow: 0 4px 20px rgba(108, 92, 231, 0.3);
}
.back-to-top.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}
.back-to-top:hover {
  box-shadow: 0 8px 32px rgba(108, 92, 231, 0.5);
  transform: translateY(-3px);
}

/* ─── Mobile Menu Overlay ───────────────────────────────────── */
.mobile-menu {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: rgba(10, 10, 15, 0.97);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 28px;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.4s ease, visibility 0.4s ease;
}
.mobile-menu.open {
  opacity: 1;
  visibility: visible;
}

.mobile-menu a {
  font-family: var(--font-heading);
  font-size: 1.6rem;
  font-weight: 600;
  color: var(--text-secondary);
  transition: color var(--transition-fast);
  transform: translateY(20px);
  opacity: 0;
  transition: transform 0.4s ease, opacity 0.4s ease, color 0.2s ease;
}
.mobile-menu.open a {
  transform: translateY(0);
  opacity: 1;
}
.mobile-menu.open a:nth-child(1) { transition-delay: 0.05s; }
.mobile-menu.open a:nth-child(2) { transition-delay: 0.1s; }
.mobile-menu.open a:nth-child(3) { transition-delay: 0.15s; }
.mobile-menu.open a:nth-child(4) { transition-delay: 0.2s; }
.mobile-menu.open a:nth-child(5) { transition-delay: 0.25s; }
.mobile-menu.open a:nth-child(6) { transition-delay: 0.3s; }
.mobile-menu a:hover { color: var(--text-primary); }

/* ═══════════════════════════════════════════════════════════════
   LIGHTBOX — Full-screen image viewer
   ═══════════════════════════════════════════════════════════════ */

.lightbox {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: rgba(0, 0, 0, 0.92);
  backdrop-filter: blur(10px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.35s ease, visibility 0.35s ease;
  cursor: zoom-out;
}

.lightbox.active {
  opacity: 1;
  visibility: visible;
}

.lightbox-content {
  position: relative;
  max-width: 90vw;
  max-height: 80vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lightbox-img {
  max-width: 90vw;
  max-height: 80vh;
  width: auto;
  height: auto;
  object-fit: contain;
  border-radius: 8px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  transform: scale(0.85);
  opacity: 0;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.35s ease;
  cursor: default;
}

.lightbox.active .lightbox-img {
  transform: scale(1);
  opacity: 1;
}

.lightbox-close {
  position: absolute;
  top: 20px;
  right: 24px;
  z-index: 10001;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: none;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  font-size: 1.3rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.lightbox-close:hover {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(1.1);
}

.lightbox-prev,
.lightbox-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10001;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: none;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  font-size: 1.1rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.lightbox-prev { left: 20px; }
.lightbox-next { right: 20px; }

.lightbox-prev:hover,
.lightbox-next:hover {
  background: rgba(255, 255, 255, 0.2);
  transform: translateY(-50%) scale(1.1);
}

.lightbox-info {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  color: rgba(255, 255, 255, 0.8);
  font-size: 0.9rem;
}

.lightbox-title {
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 1rem;
  display: block;
  margin-bottom: 4px;
}

.lightbox-counter {
  font-size: 0.8rem;
  opacity: 0.6;
}

.lightbox-desc {
  display: none;
}

.lightbox-loader {
  display: none;
}

/* ═══════════════════════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════════════════════ */

/* ─── Max 1024px ────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .about-grid {
    grid-template-columns: 1fr;
    gap: 48px;
  }

  .services-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .section-items-grid { grid-template-columns: repeat(2, 1fr); }

  .case-study {
    grid-template-columns: 1fr;
  }
  .case-study-text {
    border-right: none;
    border-bottom: 1px solid var(--border);
    padding: 28px;
  }
  .case-study-art-title {
    font-size: 1.5rem;
  }

  .contact-grid {
    grid-template-columns: 1fr;
    gap: 36px;
  }

  .contact-info { padding-right: 0; }

  .video-items-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* ─── Max 768px ─────────────────────────────────────────────── */
@media (max-width: 768px) {
  :root {
    --nav-height: 64px;
  }

  .nav-links { display: none; }
  .nav-toggle { display: flex; }

  .hero-split {
    text-align: center;
    flex-direction: column;
    min-height: calc(100vh - var(--nav-height));
    padding-bottom: 40px;
  }
  .hero-content {
    text-align: center;
    max-width: 100%;
    order: 2;
    position: relative;
    z-index: 2;
  }
  .hero-photo-wrap {
    position: relative;
    width: 90vw;
    max-width: 450px;
    height: auto;
    right: auto;
    bottom: auto;
    opacity: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    order: 1;
    margin: 0 auto 20px;
  }
  .hero-photo {
    width: 100%;
    height: auto;
  }
  .hero-photo img {
    width: 100%;
    height: auto;
    object-fit: contain;
    opacity: 1;
    border-radius: 0;
    border: none;
    box-shadow: none;
  }
  .hero-photo-glow {
    display: none;
  }
  .hero-desc { margin: 0 auto 24px; font-size: 0.92rem; }
  .hero-cta { justify-content: center; gap: 12px; }
  .hero-name { font-size: clamp(1.8rem, 7vw, 2.8rem); }
  .hero-title { font-size: 1rem; }
  .hero-badge { font-size: 0.78rem; }
  .scroll-indicator { display: none; }

  .stats-grid {
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .stat-number { font-size: 2rem; }

  .services-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .service-card { padding: 28px 24px; }

  .section-items-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .portfolio-section { padding: 60px 0 40px; }
  .portfolio-section-title { font-size: clamp(2rem, 6vw, 3rem); margin-bottom: 32px; }

  /* Layout grid responsive */
  .layout-grid.layout-grid-6,
  .layout-grid.layout-grid-9 { grid-template-columns: repeat(2, 1fr); }
  .layout-grid.layout-grid-9 .layout-cell-featured { grid-column: 1 / -1; grid-row: auto; }
  .layout-project { margin-bottom: 36px; }

  .case-study-text { padding: 24px; }
  .case-study-art-title { font-size: 1.3rem; margin-bottom: 18px; }
  .case-study-section p { font-size: 0.82rem; }
  .gallery-row.top { height: auto; }
  .gallery-row.hero { min-height: 150px; }

  .case-study-logos img { height: 45px; max-width: 120px; }

  .video-items-grid { grid-template-columns: 1fr 1fr; gap: 16px; }
  .video-play-btn { width: 56px; height: 56px; font-size: 1.3rem; }

  /* Slider responsive */
  .social-slider { padding: 0 40px; }
  .slider-arrow { width: 36px; height: 36px; font-size: 0.85rem; }

  /* Marquee responsive */
  .marquee-track { gap: 40px; }
  .marquee-logo img { height: 45px; max-width: 140px; }

  /* Layout grid responsive */
  .layout-grid.layout-grid-5 { grid-template-columns: repeat(2, 1fr); }
  .layout-grid.layout-grid-5 .layout-cell { grid-column: auto !important; }
  .layout-grid.layout-grid-7 { grid-template-columns: repeat(2, 1fr); }
  .layout-grid.layout-grid-7 .layout-cell { grid-column: auto !important; }
  .layout-grid.layout-grid-8 { grid-template-columns: repeat(2, 1fr); }
  .layout-grid.layout-grid-9 { grid-template-columns: repeat(2, 1fr); }
  .layout-project { margin-bottom: 36px; }

  /* Lightbox responsive */
  .lightbox-prev, .lightbox-next { width: 40px; height: 40px; font-size: 0.95rem; }
  .lightbox-prev { left: 10px; }
  .lightbox-next { right: 10px; }
  .lightbox-close { width: 40px; height: 40px; top: 12px; right: 12px; }

  .thank-you { padding: 80px 0; }
  .thank-you-title { letter-spacing: 4px; }

  .contact-form { padding: 28px; }
  .form-row { grid-template-columns: 1fr; }

  .footer-inner {
    flex-direction: column;
    text-align: center;
  }

  .timeline { padding-left: 32px; }
  .timeline-dot { left: -32px; width: 20px; height: 20px; }
  .timeline-card { padding: 20px; }
  .education-card { padding-left: 0; }

  .back-to-top {
    bottom: 20px;
    right: 20px;
    width: 42px;
    height: 42px;
  }
}

/* ─── Max 480px ─────────────────────────────────────────────── */
@media (max-width: 480px) {
  .section-items-grid { grid-template-columns: 1fr; }
  .portfolio-section-title { font-size: clamp(1.6rem, 7vw, 2.2rem); }

  /* Layout grid responsive */
  .layout-grid.layout-grid-2 { grid-template-columns: 1fr; }
  .layout-grid.layout-grid-3 { grid-template-columns: 1fr; }
  .layout-grid.layout-grid-4 { grid-template-columns: 1fr; }
  .layout-grid.layout-grid-5 { grid-template-columns: 1fr; }
  .layout-grid.layout-grid-5 .layout-cell { grid-column: auto !important; }
  .layout-grid.layout-grid-6 { grid-template-columns: 1fr; }
  .layout-grid.layout-grid-7 { grid-template-columns: 1fr; }
  .layout-grid.layout-grid-7 .layout-cell { grid-column: auto !important; }
  .layout-grid.layout-grid-8 { grid-template-columns: 1fr; }
  .layout-grid.layout-grid-9 { grid-template-columns: 1fr; }

  .video-items-grid { grid-template-columns: 1fr; }

  /* Slider responsive */
  .social-slider { padding: 0 32px; }
  .slider-arrow { width: 32px; height: 32px; font-size: 0.8rem; }

  /* Marquee responsive */
  .marquee-track { gap: 30px; }
  .marquee-logo img { height: 36px; max-width: 120px; }

  .thank-you-title { font-size: clamp(2.5rem, 10vw, 4rem); letter-spacing: 2px; }

  /* Hero mobile small */
  .hero-photo-wrap { width: 85vw; max-width: 380px; }
  .hero-name { font-size: clamp(1.5rem, 7vw, 2.2rem); }
  .hero-desc { font-size: 0.88rem; }
  .hero-cta { flex-direction: column; align-items: center; }
  .btn { width: 100%; justify-content: center; }

  .stat-card { padding: 20px 16px; }
  .stat-number { font-size: 1.8rem; }
  .stat-label { font-size: 0.78rem; }

  .section-title { font-size: 1.7rem; }

  /* Lightbox small mobile */
  .lightbox-img { max-width: 95vw; max-height: 75vh; border-radius: 4px; }
  .lightbox-prev, .lightbox-next { width: 34px; height: 34px; font-size: 0.85rem; }
  .lightbox-prev { left: 6px; }
  .lightbox-next { right: 6px; }
  .lightbox-close { width: 36px; height: 36px; top: 10px; right: 10px; font-size: 1rem; }
  .lightbox-info { bottom: 10px; font-size: 0.8rem; }
}

/* ─── Accessibility: reduced motion ────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
  .reveal, .reveal-left, .reveal-right, .reveal-scale {
    opacity: 1;
    transform: none;
  }
}

